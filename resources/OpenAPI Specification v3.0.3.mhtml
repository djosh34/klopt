n">:</span> <span class=3D"hljs-punctuation">{</span>
        <span class=3D"hljs-attr">"type"</span><span class=3D"hljs-punctuat=
ion">:</span> <span class=3D"hljs-string">"string"</span><span class=3D"hlj=
s-punctuation">,</span>
        <span class=3D"hljs-attr">"xml"</span><span class=3D"hljs-punctuati=
on">:</span> <span class=3D"hljs-punctuation">{</span>
