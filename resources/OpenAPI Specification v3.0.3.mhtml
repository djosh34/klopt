nctuation">,</span>
    <span class=3D"hljs-attr">"properties"</span><span class=3D"hljs-punctu=
ation">:</span> <span class=3D"hljs-punctuation">{</span>
      <span class=3D"hljs-attr">"id"</span><span class=3D"hljs-punctuation"=
>:</span> <span class=3D"hljs-punctuation">{</span>
