/span> <span class=3D"hljs-string">object</span>
        <span class=3D"hljs-attr">properties:</span>
          <span class=3D"hljs-attr">packSize:</span>
            <span class=3D"hljs-attr">type:</span> <span class=3D"hljs-stri=
ng">integer</span>
