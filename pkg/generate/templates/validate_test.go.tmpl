package {{.Package}}

import (
	"errors"
	"testing"

	testgenerator "github.com/djosh34/decode_and_validate_generator/pkg/test_generator"
)

// openAPI is the source document used to compile the generated validations.
var openAPI = []byte({{.OpenAPI}})

// TestValidations checks every generated request-body validation.
func TestValidations(t *testing.T) {
	t.Parallel()

	testgenerator.CheckJSONRequestBodies(
		t,
		openAPI,
		func(operationID string, data []byte) error {
			return errors.Join(validations[operationID].Validate(data)...)
		},
		testgenerator.DefaultOption,
	)
}
